{
  "name": "htmx-express",
  "version": "0.0.1",
  "description": "Lightweight, zero-dependency Express.js middleware for HTMX request/response handling",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.types.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/express": "^4.17.21",
    "vitest": "^1.6.0",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2",
    "express": "^4.18.2"
  },
  "license": "MIT",
  "keywords": [
    "express",
    "htmx",
    "middleware"
  ]
}
